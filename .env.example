# Copie este arquivo para ".env" (uso local) OU cole cada valor nas
# variáveis de ambiente do painel da Vercel. Nunca compartilhe estes valores.

# Supabase (Project Settings > API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (Developers > API keys / Webhooks)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Senha para publicar novas peças pela página /upload.html
# (a mesma senha também dá acesso à página /studio-orders.html, de pedidos de encomenda)
ADMIN_PASSWORD=

# Preço total (em dólares) de uma peça encomendada sob medida — o cliente paga 50%
# deste valor como sinal na hora do pedido. Pode ajustar quando quiser, sem precisar
# mexer no código.
COMMISSION_PRICE=180

# Endereço público do site depois do deploy (ex: https://animaimago.vercel.app)
SITE_URL=

# Recomendado: garante que a Vercel não tente "ajudar" interpretando o corpo
# das requisições — o código já faz isso manualmente. Defina como "0".
NODEJS_HELPERS=0
